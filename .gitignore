# 環境変数（APIキーを含むため必ずコミット除外）
.env

# Pythonキャッシュ
__pycache__/
*.pyc
*.pyo
*.pyd

# ベクトルDB（ローカル生成物）
chroma_db/

# 仮想環境
.venv/

# パッケージビルド成果物
*.egg-info/
dist/
build/

# macOSメタデータ
.DS_Store

# 生成結果出力フォルダ
output/

# IDEの設定ファイル
.vscode/
.idea/

# ログファイル
*.log

# Gmail OAuth 認証情報（絶対にコミットしない）
credentials/credentials.json
credentials/token.json

